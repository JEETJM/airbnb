<% layout("layouts/boilerplates") %>

<div class="auth-wrapper">
  <div class="auth-box auth-animate">
    <div class="auth-header">
      <div class="auth-icon-circle">🔐</div>
      <h2>Welcome Back</h2>
      <p>Login to continue to Zenvyra</p>
    </div>

    <form action="/login" method="POST" class="auth-form needs-validation" novalidate>
      <div class="form-group">
        <label for="loginUsername">Username <span>👤</span></label>
        <div class="input-wrap">
          <input
            type="text"
            id="loginUsername"
            name="username"
            class="form-control"
            placeholder="Enter your username"
            required
          >
        </div>
        <div class="invalid-feedback">
          Please enter your username.
        </div>
      </div>

      <div class="form-group">
        <label for="loginPassword">Password <span>🔒</span></label>
        <div class="input-wrap password-wrap">
          <input
            type="password"
            id="loginPassword"
            name="password"
            class="form-control"
            placeholder="Enter your password"
            required
          >
          <button type="button" class="toggle-password" data-target="loginPassword" aria-label="Show password">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
        <div class="invalid-feedback">
          Please enter your password.
        </div>
      </div>

      <button type="submit" class="auth-btn-main">
        <span>Sign In</span>
      </button>

      <p class="switch-auth">
        Don’t have an account?
        <a href="/signup">Create one</a>
      </p>
    </form>
  </div>
</div>